# Copy this file to `.env` and fill in the Anthropic key. Everything
# else has working defaults that match docker-compose.yml.

# ---- Anthropic ------------------------------------------------------------
# The only value you have to set. Without this, /api/ask returns a 500.
# Production note: a real deployment would use Bedrock with a customer-
# managed KMS key for data residency and per-tenant key isolation. Public
# Anthropic API is the deliberate prototype shortcut.
ANTHROPIC_API_KEY=

# ---- Staff auth (S2) -------------------------------------------------------
# Shared password for the operator console. The /admin/login page accepts
# this password and sets a cookie that middleware.ts checks on all admin
# write routes (/api/overrides, /api/needs-attention/*/resolve-with-entry).
# Demo default — change in any real deployment.
STAFF_AUTH_TOKEN=brightdesk-demo-2026

# ---- MinIO / S3 wiring ----------------------------------------------------
# These have defaults in docker-compose.yml; override only if you're running
# the app outside compose (e.g. pointing at a real S3 bucket).
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_HANDBOOK_BUCKET=handbook
# STORAGE_EVENTS_BUCKET=events

# MinIO server credentials. Must match STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY
# above. Only override if you're changing the dev password from the default.
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
