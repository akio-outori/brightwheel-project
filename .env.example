# Anthropic API
# Production note: a real deployment would use Bedrock with a customer-managed
# KMS key for data residency and per-tenant key isolation. Public Anthropic
# API is the deliberate prototype shortcut.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# MinIO connection (used by the Next.js app to talk to object storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Bucket names. Tests override these to handbook-test / events-test
# via vitest.setup.ts to avoid polluting the seeded handbook.
STORAGE_HANDBOOK_BUCKET=handbook
STORAGE_EVENTS_BUCKET=events
